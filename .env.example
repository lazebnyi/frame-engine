# Copy this file to .env and adjust values for your environment.
# For Docker Compose, REDIS_URL uses the service name (redis://redis:6379).
# For local development outside Docker, use redis://localhost:6379.

REDIS_URL=redis://redis:6379
SHARED_PATH=/shared/batches

# stream_reader
BATCH_SIZE=4
MAX_DRIFT_MS=150
MAX_INFLIGHT_BATCHES=4
BUFFER_MAXLEN=10
BACKOFF_INITIAL=0.5
BACKOFF_FACTOR=2.0
BACKOFF_MAX=30.0
STABLE_FRAMES=5
HEALTH_INTERVAL_S=5.0
CAMERA_TIMEOUT_S=10.0

# frame_processor
GPU_LATENCY_MS=20
